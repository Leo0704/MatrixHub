{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM"],
    "outDir": "./dist/preload",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src/preload/**/*", "src/shared/**/*"],
  "exclude": ["src/renderer/**/*", "src/main/**/*", "src/service/**/*"]
}
